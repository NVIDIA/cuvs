#include <neighbors/ivf_rabitq/jit_lto_kernels/compute_inner_products_with_bitwise_block_sort_impl.cuh>
#include <neighbors/ivf_rabitq/jit_lto_kernels/kernel_def.hpp>

namespace {

constexpr bool is_signed = @signed_value@;

}  // namespace

namespace cuvs::neighbors::ivf_rabitq::detail {

extern "C" __global__ void compute_inner_products_with_bitwise_block_sort(
  const ComputeInnerProductsKernelParams params)
{
  compute_inner_products_with_bitwise_block_sort_impl<is_signed>(params);
}

static_assert(std::is_same_v<decltype(compute_inner_products_with_bitwise_block_sort),
                             compute_inner_products_with_lut_func_t>);

}  // namespace cuvs::neighbors::ivf_rabitq::detail
