  }                                                                                               \
                                                                                                  \
  void serialize(                                                                                 \
    const raft::resources& res,                                                                   \
    const cuvs::neighbors::mg_index<cagra::device_padded_index<T, IdxT>, T, IdxT>& index,         \
    const std::string& filename)                                                                  \
  {                                                                                               \
    cuvs::neighbors::snmg::detail::serialize(res, index, filename);                               \
  }                                                                                               \
                                                                                                  \
  void serialize(                                                                                 \
    const raft::resources& res,                                                                   \
    const cuvs::neighbors::mg_index<cagra::device_standard_index<T, IdxT>, T, IdxT>& index,       \
    const std::string& filename)                                                                  \
  {                                                                                               \
    cuvs::neighbors::snmg::detail::serialize(res, index, filename);                               \
  }                                                                                               \
                                                                                                  \
  template <>                                                                                     \
  CUVS_EXPORT void deserialize<T, IdxT>(                                                          \
    const raft::resources& res,                                                                   \
    const std::string& filename,                                                                  \
    cuvs::neighbors::mg_index<cagra::device_padded_index<T, IdxT>, T, IdxT>* index)               \
  {                                                                                               \
    *index =                                                                                      \
      cuvs::neighbors::mg_index<cagra::device_padded_index<T, IdxT>, T, IdxT>(res, filename);     \
  }                                                                                               \
                                                                                                  \
  template <>                                                                                     \
  CUVS_EXPORT void deserialize<T, IdxT>(                                                          \
    const raft::resources& res,                                                                   \
    const std::string& filename,                                                                  \
    cuvs::neighbors::mg_index<cagra::device_standard_index<T, IdxT>, T, IdxT>* index)             \
  {                                                                                               \
    *index =                                                                                      \
      cuvs::neighbors::mg_index<cagra::device_standard_index<T, IdxT>, T, IdxT>(res, filename);   \
  }                                                                                               \
                                                                                                  \
  template <>                                                                                     \
  CUVS_EXPORT void distribute<T, IdxT>(                                                           \
    const raft::resources& res,                                                                   \
    const std::string& filename,                                                                  \
    cuvs::neighbors::mg_index<cagra::device_standard_index<T, IdxT>, T, IdxT>* index)             \
  {                                                                                               \
    auto idx =                                                                                    \
      cuvs::neighbors::mg_index<cagra::device_standard_index<T, IdxT>, T, IdxT>(res, REPLICATED); \
    cuvs::neighbors::snmg::detail::deserialize_and_distribute(res, idx, filename);                \
    *index = std::move(idx);                                                                      \
  }                                                                                               \
                                                                                                  \
  template <>                                                                                     \
  CUVS_EXPORT void distribute<T, IdxT>(                                                           \
    const raft::resources& res,                                                                   \
    const std::string& filename,                                                                  \
    cuvs::neighbors::mg_index<cagra::device_padded_index<T, IdxT>, T, IdxT>* index)               \
  {                                                                                               \
    auto idx =                                                                                    \
      cuvs::neighbors::mg_index<cagra::device_padded_index<T, IdxT>, T, IdxT>(res, REPLICATED);   \
    cuvs::neighbors::snmg::detail::deserialize_and_distribute(res, idx, filename);                \
    *index = std::move(idx);                                                                      \
  }                                                                                               \
  }                                                                                               \
  template CUVS_EXPORT cuvs::neighbors::                                                          \
    mg_index<cuvs::neighbors::cagra::device_standard_index<T, IdxT>, T, IdxT>::mg_index(          \
      const raft::resources&);                                                                    \
  template CUVS_EXPORT cuvs::neighbors::                                                          \
    mg_index<cuvs::neighbors::cagra::device_standard_index<T, IdxT>, T, IdxT>::mg_index(          \
      const raft::resources&, cuvs::neighbors::distribution_mode);                                \
  template CUVS_EXPORT cuvs::neighbors::                                                          \
    mg_index<cuvs::neighbors::cagra::device_standard_index<T, IdxT>, T, IdxT>::mg_index(          \
      const raft::resources&, const std::string&);                                                \
  template CUVS_EXPORT cuvs::neighbors::                                                          \
    mg_index<cuvs::neighbors::cagra::device_padded_index<T, IdxT>, T, IdxT>::mg_index(            \
      const raft::resources&);                                                                    \
  template CUVS_EXPORT cuvs::neighbors::                                                          \
    mg_index<cuvs::neighbors::cagra::device_padded_index<T, IdxT>, T, IdxT>::mg_index(            \
      const raft::resources&, cuvs::neighbors::distribution_mode);                                \
  template CUVS_EXPORT cuvs::neighbors::                                                          \
    mg_index<cuvs::neighbors::cagra::device_padded_index<T, IdxT>, T, IdxT>::mg_index(            \
      const raft::resources&, const std::string&);
CUVS_INST_MG_CAGRA(@data_type@, uint32_t);

#undef CUVS_INST_MG_CAGRA
